<view class="page">
  <t-navbar title="{{ariaLabel}}" t-class-title="nav-title" />
  <view class="tab-bar__content">
    <home wx:if="{{value === 'home'}}"></home>
    <medicine wx:if="{{value === 'medicine'}}"></medicine> 
    <mine wx:if="{{value === 'mine'}}"></mine>
  </view>


  <tab-bar
    items="{{ tabs }}"
    current="{{ value }}"
    bind:change="handleChange" />
  </view>
